{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "categories": {
    "correctness": "warn",
    "suspicious": "warn",
    "perf": "warn"
  },
  "plugins": ["typescript", "unicorn", "oxc"],
  "ignorePatterns": ["dist", ".astro", "node_modules"],
  "overrides": [
    {
      "files": ["*.astro"],
      "rules": {
        "no-unused-vars": "off"
      }
    }
  ]
}
