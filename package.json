{
  "name": "bradenm.co.uk",
  "version": "0.0.0",
  "private": true,
  "homepage": "https://github.com/braden1996/bradenm.co.uk",
  "bugs": {
    "url": "https://github.com/braden1996/bradenm.co.uk/issues"
  },
  "license": "MIT",
  "author": "Braden Marshall <braden1996@hotmail.co.uk>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/braden1996/bradenm.co.uk.git"
  },
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "check": "bun run check:format && bun run check:types && bun run check:lint && bun run check:spelling",
    "check:format": "prettier --check --experimental-cli .",
    "check:types": "astro check --tsconfig tsconfig.lib.json",
    "check:lint": "oxlint",
    "check:spelling": "cspell \"**/*.{js,mjs,ts,astro}\" --no-must-find-files",
    "fix": "bun run fix:format && bun run fix:lint",
    "fix:format": "prettier --write --experimental-cli .",
    "fix:lint": "oxlint --write"
  },
  "dependencies": {
    "astro": "^5.18.0"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.6",
    "cspell": "^9.7.0",
    "oxlint": "^1.50.0",
    "prettier": "^3.8.1",
    "prettier-plugin-astro": "^0.14.1",
    "typescript": "5.9.3"
  }
}
