{
  "name": "bradenm.co.uk",
  "version": "0.0.0",
  "private": true,
  "repository": {
    "type": "git",
    "url": "git+https://github.com/braden1996/bradenm.co.uk.git"
  },
  "author": "Braden Marshall <braden1996@hotmail.co.uk>",
  "license": "MIT",
  "homepage": "https://github.com/braden1996/bradenm.co.uk",
  "bugs": {
    "url": "https://github.com/braden1996/bradenm.co.uk/issues"
  },
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "lint": "oxlint",
    "lint-fix": "bun run lint --write",
    "format-fix": "bun run dprint fmt",
    "format-check": "bun run dprint check",
    "type-check": "astro check --tsconfig tsconfig.lib.json",
    "spell-check": "cspell \"**/*.{js,ts,astro}\" --no-must-find-files",
    "ci-check": "bun run format-check && bun run type-check && bun run lint && bun run spell-check"
  },
  "dependencies": {
    "astro": "^5.5.0"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.0",
    "dprint": "^0.45.0",
    "cspell": "^8.3.2",
    "oxlint": "^0.2.7",
    "typescript": "5.3.3"
  }
}
